#!/bin/sh

. /lib/functions.sh

MARKER="/etc/config/.be7000_wireless_defaults"

[ "$(board_name)" = "xiaomi,be7000" ] || exit 0
[ -e "$MARKER" ] && exit 0

wait_for_radios()
{
	local timeout="${1:-0}"
	local i=0

	while :; do
		[ -s /etc/config/wireless ] || wifi config >/dev/null 2>&1

		if uci -q get wireless.radio0 >/dev/null &&
		   uci -q get wireless.radio1 >/dev/null &&
		   uci -q get wireless.default_radio0 >/dev/null &&
		   uci -q get wireless.default_radio1 >/dev/null; then
			return 0
		fi

		[ "$i" -ge "$timeout" ] && return 1
		i=$((i + 1))
		sleep 1
	done
}

apply_defaults()
{
	uci -q batch <<-EOF
		set wireless.radio0.channel='auto'
		set wireless.radio0.htmode='HE40'
		set wireless.default_radio0.ssid='BE7000-2G'
		set wireless.radio1.channel='auto'
		set wireless.radio1.htmode='EHT80'
		set wireless.default_radio1.ssid='BE7000-5G'
		commit wireless
	EOF

	touch "$MARKER"
}

case "$1" in
	--wait)
		wait_for_radios "${2:-20}" || exit 1
		;;
	*)
		wait_for_radios 0 || exit 1
		;;
esac

apply_defaults

exit 0
